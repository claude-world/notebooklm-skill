# NotebookLM Skill 設定
# 複製為 .env 並填入值

# Google 帳號（用於 NotebookLM 驗證）
# 執行一次性瀏覽器登入：python3 -m notebooklm login
# Session 自動儲存至 ~/.notebooklm/storage_state.json
# 不需要 OAuth Client ID 或 API Key

# 選用：預設設定
# NOTEBOOKLM_DEFAULT_DEPTH=5          # 研究查詢數 (1-10)
# NOTEBOOKLM_DEFAULT_FORMAT=json      # 輸出格式: json, markdown, text
# NOTEBOOKLM_MAX_SOURCES=50           # 每個筆記本最大來源數

# 選用：trend-pulse 整合
# TREND_PULSE_URL=http://localhost:3002  # trend-pulse MCP 伺服器 URL

# 選用：Threads 發布（需要 threads-viral-agent）
# THREADS_TOKEN=your_threads_token
# THREADS_USER_ID=your_user_id

# 選用：速率限制
# NLM_MAX_NOTEBOOKS_PER_HOUR=10
# NLM_REQUEST_DELAY_SECONDS=2
